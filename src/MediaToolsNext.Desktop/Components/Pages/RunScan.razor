@page "/run"
@inject ScanWorkflowState State
@inject IScanPreviewService PreviewService
@inject IScannerPipeline Pipeline
@inject ScanControl ScanControl
@implements IDisposable

<div class="page-stack">
    <header class="page-header">
        <p class="eyebrow">Step 5</p>
        <h1>Run</h1>
        <p>Preview first, then scan when preflight is clean.</p>
    </header>

    @if (!string.IsNullOrWhiteSpace(State.Message)) { <div class="notice">@State.Message</div> }

    <section class="panel">
        <h2>Preflight</h2>
        <div class="preflight-list">
            @foreach (var error in Errors) { <div class="preflight-item error"><strong>Fix</strong><span>@error</span></div> }
            @if (!Errors.Any()) { <div class="preflight-item ok"><strong>OK</strong><span>Ready to preview or scan.</span></div> }
        </div>
    </section>

    <section class="run-status @(State.IsBusy ? "active" : "")">
        <strong>@(State.IsBusy ? "⏳ " : "")@RunStatus</strong>
        <span>@RunDetail</span>
    </section>

    @* P1 fix: "Start scan" is the primary CTA; "Run preview" is secondary *@
    <section class="action-bar">
        <button class="secondary" disabled="@(State.IsBusy || Errors.Any())" @onclick="PreviewAsync"
                title="@(Errors.Any() ? "Fix preflight errors before previewing" : "Discover matching files without writing anything")">
            @(State.IsPreviewing ? "Previewing…" : "Run preview")
        </button>
        <button class="btn-primary" disabled="@(State.IsBusy || Errors.Any())" @onclick="RunAsync"
                title="@(Errors.Any() ? "Fix preflight errors before scanning" : "Validate and process matching files")">
            @(State.IsScanning ? "Scanning…" : "Start scan")
        </button>
        @if (State.IsScanning)
        {
            <button class="secondary" disabled="@ScanControl.IsPaused" @onclick="Pause">Pause</button>
            <button class="secondary" disabled="@(!ScanControl.IsPaused)" @onclick="Resume">Resume</button>
            <button class="danger" @onclick="Cancel">Cancel</button>
        }
    </section>

    @if (State.Results.Any() || State.IsScanning)
    {
        <section class="panel live-counts-panel">
            <!-- Row 1: pipeline input funnel -->
            <p class="live-counts-group-label">Input</p>
            <div class="live-counts">
                <div class="live-count searched" title="Every file the discoverer touched before any filter.">
                    <span class="live-count-value">@State.TotalSearched.ToString("N0")</span>
                    <span class="live-count-label">Searched</span>
                </div>
                <div class="live-count filtered" title="Dropped by min/max file size filter.">
                    <span class="live-count-value">@State.FilteredOutSize.ToString("N0")</span>
                    <span class="live-count-label">Filtered · size</span>
                </div>
                <div class="live-count filtered" title="Dropped by include/exclude filename pattern.">
                    <span class="live-count-value">@State.FilteredOutPattern.ToString("N0")</span>
                    <span class="live-count-label">Filtered · pattern</span>
                </div>
                <div class="live-count filtered" title="Dropped because file family not enabled.">
                    <span class="live-count-value">@State.FilteredOutFamily.ToString("N0")</span>
                    <span class="live-count-label">Filtered · family</span>
                </div>
                <div class="live-count total" title="Files that passed all discoverer filters and entered the validation pipeline.">
                    <span class="live-count-value">@State.Results.Count.ToString("N0")</span>
                    <span class="live-count-label">Matched</span>
                </div>
                <div class="live-count total" title="Total size of all matched files so far.">
                    <span class="live-count-value">@State.MatchedMb.ToString("N1")</span>
                    <span class="live-count-label">Matched MB</span>
                </div>
            </div>

            <!-- Row 2: validation outcomes -->
            <p class="live-counts-group-label">Outcomes</p>
            <div class="live-counts">
                <div class="live-count valid">
                    <span class="live-count-value">@State.GetStatusCount(ValidationStatus.Valid).ToString("N0")</span>
                    <span class="live-count-label">Valid</span>
                </div>
                <div class="live-count corrupt">
                    <span class="live-count-value">@State.GetStatusCount(ValidationStatus.Corrupt).ToString("N0")</span>
                    <span class="live-count-label">Corrupt</span>
                </div>
                <div class="live-count unknown">
                    <span class="live-count-value">@State.GetStatusCount(ValidationStatus.Unknown).ToString("N0")</span>
                    <span class="live-count-label">Unknown</span>
                </div>
                <div class="live-count error">
                    <span class="live-count-value">@State.GetStatusCount(ValidationStatus.Error).ToString("N0")</span>
                    <span class="live-count-label">Error</span>
                </div>
                <div class="live-count skipped" title="Reached pipeline but had no matching validator (category disabled after start, or access-denied stub).">
                    <span class="live-count-value">@State.GetStatusCount(ValidationStatus.Skipped).ToString("N0")</span>
                    <span class="live-count-label">Skipped</span>
                </div>
                <div class="live-count perf">
                    <span class="live-count-value">@State.Performance.FilesPerSecond.ToString("N1")</span>
                    <span class="live-count-label">Files/s</span>
                </div>
            </div>

            <!-- Row 3: time -->
            <p class="live-counts-group-label">Time</p>
            <div class="live-counts">
                <div class="live-count perf">
                    <span class="live-count-value">@FormatElapsed(State.Elapsed)</span>
                    <span class="live-count-label">Elapsed</span>
                </div>
                @if (State.Remaining.HasValue)
                {
                    <div class="live-count perf">
                        <span class="live-count-value">@FormatElapsed(State.Remaining.Value)</span>
                        <span class="live-count-label">Remaining</span>
                    </div>
                }
            </div>
        </section>
    }

    <section class="summary-grid">
        <div><strong>@(State.Preview?.TotalFiles ?? 0)</strong><span>Preview files</span></div>
        <div><strong>@(State.Preview?.TotalDirectories ?? 0)</strong><span>Preview folders</span></div>
        <div><strong>@PreviewMb</strong><span>Preview MB</span></div>
        <div><strong>@State.LastCompletionReason</strong><span>Completion</span></div>
    </section>

    <section class="panel run-facts">
        <h2>Current run</h2>
        @if (State.LastRunStartedLocal is null)
        {
            <p class="muted empty-state">No scan has been run yet in this session.</p>
        }
        else
        {
            <div class="info-grid">
                <div><strong>@State.LastRunType</strong><span>Type</span></div>
                <div><strong>@FormatTime(State.LastRunStartedLocal)</strong><span>Started</span></div>
                <div><strong>@FormatTime(State.LastRunEndedLocal)</strong><span>Ended</span></div>
            </div>
            <p class="muted" style="margin-top:8px">@State.LastRunSettings</p>
        }
    </section>

    @if (State.Preview is not null)
    {
        <section class="panel">
            <h2>Preview breakdown</h2>
            <div class="summary-grid">
                @foreach (var item in State.Preview.FilesByCategory.Where(x => x.Value > 0))
                {
                    <div><strong>@item.Value</strong><span>@item.Key</span></div>
                }
                @if (!State.Preview.FilesByCategory.Any(x => x.Value > 0))
                {
                    <div><strong>0</strong><span>No matching files found. Check source path, media families, size filters, and include/exclude patterns.</span></div>
                }
            </div>
        </section>
    }
</div>

@code {
    private List<string> Errors => State.PreflightErrors().ToList();
    private string PreviewMb => ((State.Preview?.TotalBytes ?? 0) / 1048576d).ToString("N1");
    private string RunStatus => State.IsScanning ? (ScanControl.IsPaused ? "Paused" : "Scanning") : State.IsPreviewing ? "Previewing" : "Idle";
    private string RunDetail => State.IsScanning
        ? $"{State.Results.Count:N0} files processed, {State.Performance.FilesPerSecond:N1} files/s."
        : State.IsPreviewing
            ? "Discovering matched files only. No files are copied or changed."
            : "No active job. Preview or scan can be started.";

    private static string FormatTime(DateTimeOffset? value) => value?.ToString("yyyy-MM-dd HH:mm:ss") ?? "-";
    private static string FormatElapsed(TimeSpan t) => t.TotalHours >= 1
        ? $"{(int)t.TotalHours}h {t.Minutes:D2}m {t.Seconds:D2}s"
        : $"{t.Minutes:D2}m {t.Seconds:D2}s";

    protected override void OnInitialized()
    {
        State.Changed += OnStateChanged;
        // Timer to keep elapsed/remaining updating while scanning even if no new files arrive
        _clockTimer = new System.Threading.Timer(_ =>
        {
            if (State.IsScanning) InvokeAsync(StateHasChanged);
        }, null, 1000, 1000);
    }

    public void Dispose()
    {
        State.Changed -= OnStateChanged;
        _clockTimer?.Dispose();
    }

    private System.Threading.Timer? _clockTimer;

    private void OnStateChanged() => InvokeAsync(StateHasChanged);

    private IProgress<ScanDiscoveryEvent> BuildDiscoveryProgress() =>
        new Progress<ScanDiscoveryEvent>(e =>
        {
            switch (e.Type)
            {
                case DiscoveryEventType.Searched:           State.IncrementSearched();          break;
                case DiscoveryEventType.FilteredOutSize:    State.IncrementFilteredOutSize();   break;
                case DiscoveryEventType.FilteredOutPattern: State.IncrementFilteredOutPattern(); break;
                case DiscoveryEventType.FilteredOutFamily:  State.IncrementFilteredOutFamily();  break;
            }
        });

    private async Task PreviewAsync()
    {
        if (Errors.Any()) { State.Message = "Preview blocked: " + Errors[0]; State.NotifyChanged(); return; }
        if (!State.TryStartPreview()) { State.Message = "A preview or scan is already running."; State.NotifyChanged(); return; }
        var limit = new ScanLimitState();
        try
        {
            State.Preview = await PreviewService.PreviewAsync(State.BuildOptions(limit), CancellationToken.None);
            State.LastCompletionReason = limit.StopReason ?? "Source exhausted.";
            var message = State.Preview.TotalFiles == 0
                ? "Preview complete: no matching files found."
                : $"Preview complete: {State.Preview.TotalFiles:N0} matching files found.";
            State.FinishPreview(message);
        }
        catch (Exception ex) { State.LastCompletionReason = "Preview failed."; State.FinishPreview("Preview failed: " + ex.Message); }
        finally { if (State.IsPreviewing) State.FinishPreview(State.Message ?? "Preview stopped."); }
    }

    private async Task RunAsync()
    {
        if (Errors.Any()) { State.Message = "Scan blocked: " + Errors[0]; State.NotifyChanged(); return; }
        if (!State.TryStartScan()) { State.Message = "A preview or scan is already running."; State.NotifyChanged(); return; }
        var limit    = new ScanLimitState();
        var progress = State.CreateScanProgress();
        var discoveryProgress = BuildDiscoveryProgress();
        try
        {
            State.Summary = await Pipeline.RunAsync(State.BuildOptions(limit), progress, State.ScanCancellationToken, discoveryProgress);
            State.LastCompletionReason = State.Summary.CompletionReason;
            State.FlushPendingScanResults();
            State.FinishScan("Scan complete.");
        }
        catch (OperationCanceledException) { State.LastCompletionReason = "Cancelled.";   State.FlushPendingScanResults(); State.FinishScan("Scan cancelled."); }
        catch (Exception ex)               { State.LastCompletionReason = "Scan failed."; State.FlushPendingScanResults(); State.FinishScan("Scan failed: " + ex.Message); }
        finally
        {
            if (State.IsScanning) { State.FlushPendingScanResults(); State.FinishScan(State.Message ?? "Scan stopped."); }
            ScanControl.Resume();
        }
    }

    private void Pause()  { ScanControl.Pause();  State.NotifyChanged(); }
    private void Resume() { ScanControl.Resume(); State.NotifyChanged(); }
    private void Cancel() => State.CancelScan();
}

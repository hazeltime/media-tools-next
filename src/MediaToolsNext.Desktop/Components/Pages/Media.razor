@page "/media"
@inject ScanWorkflowState State

<div class="page-stack">
    <header class="page-header">
        <p class="eyebrow">Step 2</p>
        <h1>Media and filters</h1>
        <p>Choose which file families to scan and apply any filename or size filters.</p>
    </header>

    <section class="panel">
        <h2>Image scan preset</h2>
        <div class="card-grid three">
            @foreach (var profile in ScanProfiles.All)
            {
                <button class="select-card @(State.ProfileName == profile.Name ? "active" : "")" @onclick="() => State.ApplyProfile(profile.Name)">
                    <strong>@Label(profile)</strong><span>@profile.Description</span><small>@ScanWorkflowState.DepthLabel(profile.ValidationDepth)</small>
                </button>
            }
        </div>
    </section>

    <section class="panel">
        <h2>File families</h2>
        <div class="form-grid four">
            <label class="choice"><input type="checkbox" @bind="State.EnableImages" /> Images</label>
            <label class="choice"><input type="checkbox" @bind="State.EnableVideo" /> Video</label>
            <label class="choice"><input type="checkbox" @bind="State.EnableAudio" /> Audio</label>
            <label class="choice"><input type="checkbox" @bind="State.EnableDocuments" /> Documents</label>
        </div>
        @if (State.EnableImages)
        {
            <div class="extension-cloud">
                @foreach (var ext in ImageExtensions) { <span>@ext</span> }
            </div>
        }
    </section>

    @if (State.EnableImages)
    {
        <section class="panel">
            <h2>Custom image types</h2>
            <div class="form-grid two">
                <label>
                    Extra image extensions
                    <small>Accepts jpg, .jpg, or *.jpg separated by spaces.</small>
                    <textarea rows="3" @bind="State.CustomImageExtensionsText" />
                </label>
                <label>
                    Custom image filename regex
                    <small class="@(ScanWorkflowState.IsRegexValid(State.CustomImageRegex) ? "" : "regex-invalid")">
                        @(ScanWorkflowState.IsRegexValid(State.CustomImageRegex) ? "Regex is valid or empty." : "⚠ Regex is invalid.")
                    </small>
                    <input @bind="State.CustomImageRegex" />
                </label>
            </div>
        </section>

        <section class="panel">
            <h2>Include filters</h2>
            <div class="form-grid two">
                <label>Minimum file size KB <input type="number" min="0" @bind="State.MinFileKb" /></label>
                <label>Maximum file size MB <input type="number" min="0" @bind="State.MaxFileMb" /></label>
                <label>Include filename wildcards <small>Example: IMG_* *.jpg</small><textarea rows="3" @bind="State.IncludePatternsText" /></label>
                <label>Exclude filename wildcards <small>Example: thumb_* *_small.*</small><textarea rows="3" @bind="State.ExcludePatternsText" /></label>
            </div>
        </section>
    }
</div>

@code {
    private static readonly string[] ImageExtensions = GetImageExtensions();

    private static string Label(ScanProfile profile) => profile.Name switch
    {
        "quick-images"   => "Quick image check",
        "standard-images" => "Medium image check",
        "deep-images"    => "In-depth image check",
        "all-media"      => "All media",
        _                => profile.Name
    };

    private static string[] GetImageExtensions()
    {
        var field = typeof(SupportedMedia).GetField("ExtensionToCategory", System.Reflection.BindingFlags.NonPublic | System.Reflection.BindingFlags.Static);
        if (field?.GetValue(null) is not System.Collections.Generic.IEnumerable<System.Collections.Generic.KeyValuePair<string, MediaCategory>> entries)
            return [];

        return entries
            .Where(pair => pair.Value == MediaCategory.Image)
            .Select(pair => pair.Key)
            .OrderBy(x => x)
            .ToArray();
    }
}

@page "/tools"
@inject IExternalToolProbe ToolProbe
@inject ToolInstallService Installer

<div class="page-stack">
    <header class="page-header">
        <p class="eyebrow">System</p>
        <h1>Tools</h1>
        <p>Check external validators and install missing tools with Chocolatey or winget.</p>
    </header>

    @if (!string.IsNullOrWhiteSpace(_message)) { <div class="notice">@_message</div> }

    <section class="panel">
        <div class="panel-title-row">
            <div>
                <h2>Validator tools</h2>
                <p class="muted">The app probes these commands directly. Refresh after install or upgrade if PATH changed.</p>
            </div>
            <div class="action-bar">
                @if (IsBusy)
                {
                    <button class="danger" @onclick="CancelOperation">Cancel operation</button>
                }
                <button class="secondary" disabled="@IsBusy" @onclick="RefreshTools">Refresh status</button>
                <button disabled="@IsBusy" @onclick="UpgradeAllAsync">Check and upgrade all</button>
            </div>
        </div>
        <div class="tool-status-grid">
            @foreach (var tool in _toolStatuses)
            {
                <div class="tool-status-card @(tool.IsAvailable ? "ok" : "missing")">
                    <div>
                        <strong>@tool.Name</strong>
                        <span class="tool-state @(tool.IsAvailable ? "ok" : "missing")">@ToolState(tool)</span>
                    </div>
                    <p>@ToolDetail(tool)</p>
                    <small title="@tool.Path">@((tool.Path ?? "Not found on PATH"))</small>
                    <div class="action-bar">
                        <button class="secondary" disabled="@IsBusy" @onclick="() => InstallAsync(tool.Name)">
                            @InstallButtonText(tool)
                        </button>
                        <button class="secondary" disabled="@IsBusy || !tool.IsAvailable" @onclick="() => UpgradeAsync(tool.Name)">
                            @UpgradeButtonText(tool.Name)
                        </button>
                    </div>
                </div>
            }
        </div>
    </section>

    <section class="panel">
        <h2>Install behavior</h2>
        <p class="muted">Install runs in the background with `choco install -y --no-progress` first. If Chocolatey is unavailable or fails, the app tries `winget install --silent` with package agreements accepted. Some installs may still require administrator permission or PATH refresh before the app sees the tool.</p>
    </section>
</div>

@code {
    private string? _installing;
    private string? _upgrading;
    private string? _message;
    private IReadOnlyList<ToolStatus> _toolStatuses = [];
    private bool IsBusy => _installing is not null || _upgrading is not null;
    private CancellationTokenSource? _installCts;

    protected override void OnInitialized()
    {
        LoadToolStatuses();
    }

    private static string ToolState(ToolStatus tool) =>
        tool.IsAvailable ? "Already installed" : "Missing / not installed";

    private static string ToolDetail(ToolStatus tool) =>
        tool.IsAvailable ? tool.Version ?? "Installed, version unavailable" : tool.Detail ?? "Command is not available.";

    private string InstallButtonText(ToolStatus tool)
    {
        if (_installing == tool.Name) return "Installing...";
        if (tool.IsAvailable) return tool.Name == "ffprobe" ? "Reinstall ffmpeg" : "Reinstall";
        return tool.Name == "ffprobe" ? "Install ffmpeg" : "Install";
    }

    private string UpgradeButtonText(string toolName) =>
        _upgrading == toolName || _upgrading == "*" ? "Checking..." : "Check / upgrade";

    private void RefreshTools()
    {
        ToolProbe.Refresh();
        LoadToolStatuses();
        _message = "Tool status refreshed.";
    }

    private void LoadToolStatuses()
    {
        _toolStatuses = ToolProbe.GetStatuses();
    }

    private void CancelOperation()
    {
        _installCts?.Cancel();
        _message = "Cancelling operation...";
    }

    private async Task<string> SaveLogIfNeededAsync(string action, string toolName, string output)
    {
        if (output.Length <= 500) return TrimOutput(output);

        try
        {
            var appData = Path.Combine(Environment.GetFolderPath(Environment.SpecialFolder.LocalApplicationData), "media-tools-next", "logs");
            Directory.CreateDirectory(appData);
            var timestamp = DateTime.UtcNow.ToString("yyyyMMdd_HHmmss");
            var filename = $"tool-{action}-{toolName}-{timestamp}.log";
            var logPath = Path.Combine(appData, filename);
            await File.WriteAllTextAsync(logPath, output);
            return $"{output[..500]}...\n[Full log saved to: {logPath}]";
        }
        catch (Exception ex)
        {
            return $"{output[..500]}...\n[Failed to save full log: {ex.Message}]";
        }
    }

    private async Task InstallAsync(string toolName)
    {
        _installing = toolName;
        _message = $"Installing {toolName}...";
        _installCts = new CancellationTokenSource();
        try
        {
            var result = await Installer.InstallAsync(toolName, _installCts.Token);
            var outputMsg = await SaveLogIfNeededAsync("install", toolName, result.Output);
            _message = result.Success
                ? $"Install command completed: {result.Command}. Refreshed tool status; restart the app if PATH still has not updated."
                : $"Install failed: {result.Command}. {outputMsg}";
            ToolProbe.Refresh();
            LoadToolStatuses();
        }
        catch (OperationCanceledException)
        {
            _message = "Installation cancelled.";
        }
        catch (Exception ex)
        {
            _message = $"Installation error: {ex.Message}";
        }
        finally
        {
            _installing = null;
            _installCts?.Dispose();
            _installCts = null;
        }
    }

    private async Task UpgradeAsync(string toolName)
    {
        _upgrading = toolName;
        _message = $"Checking/upgrading {toolName}...";
        _installCts = new CancellationTokenSource();
        try
        {
            var result = await Installer.UpgradeAsync(toolName, _installCts.Token);
            var outputMsg = await SaveLogIfNeededAsync("upgrade", toolName, result.Output);
            _message = result.Success
                ? $"Upgrade check completed: {result.Command}. {outputMsg}"
                : $"Upgrade check failed: {result.Command}. {outputMsg}";
            ToolProbe.Refresh();
            LoadToolStatuses();
        }
        catch (OperationCanceledException)
        {
            _message = "Upgrade cancelled.";
        }
        catch (Exception ex)
        {
            _message = $"Upgrade error: {ex.Message}";
        }
        finally
        {
            _upgrading = null;
            _installCts?.Dispose();
            _installCts = null;
        }
    }

    private async Task UpgradeAllAsync()
    {
        _upgrading = "*";
        _message = "Checking/upgrading all validator tools...";
        _installCts = new CancellationTokenSource();
        try
        {
            var result = await Installer.UpgradeAllAsync(_toolStatuses.Select(t => t.Name), _installCts.Token);
            var outputMsg = await SaveLogIfNeededAsync("upgrade-all", "all", result.Output);
            _message = result.Success
                ? $"Upgrade checks completed. {outputMsg}"
                : $"One or more upgrade checks failed. {outputMsg}";
            ToolProbe.Refresh();
            LoadToolStatuses();
        }
        catch (OperationCanceledException)
        {
            _message = "Upgrade operation cancelled.";
        }
        catch (Exception ex)
        {
            _message = $"Upgrade operation error: {ex.Message}";
        }
        finally
        {
            _upgrading = null;
            _installCts?.Dispose();
            _installCts = null;
        }
    }

    private static string TrimOutput(string output) =>
        output.Length <= 500 ? output : output[..500] + "...";
}

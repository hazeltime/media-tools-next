@page "/tools"
@inject IExternalToolProbe ToolProbe
@inject ToolInstallService Installer

<div class="page-stack">
    <header class="page-header">
        <p class="eyebrow">System Configuration</p>
        <h1>Tools & Dependencies</h1>
        <p>Manage external validators required for media processing and install missing tools automatically.</p>
    </header>

    @if (!string.IsNullOrWhiteSpace(_message))
    {
        <div class="notice">@_message</div>
    }

    <section class="panel">
        <h2>Installation Behavior</h2>
        <p class="muted">Installs run in the background with <code>choco install -y --no-progress</code> first. If Chocolatey is unavailable, the app falls back to <code>winget install --silent</code>. Some tool installations may require administrator permissions or a system restart to update the PATH environment variable.</p>
    </section>

    <section class="panel">
        <div class="panel-title-row">
            <div>
                <h2>Validator Tools</h2>
                <p class="muted">Directly probed commands. Refresh status after installation to detect PATH changes.</p>
            </div>
            <div class="action-bar">
                @if (IsBusy)
                {
                    <button class="btn btn-danger" @onclick="CancelOperation">
                        <span class="bi bi-x-circle"></span> Cancel
                    </button>
                }
                <button class="btn btn-secondary" disabled="@IsBusy" @onclick="RefreshTools">
                    <span class="bi bi-arrow-clockwise"></span> Refresh Status
                </button>
                <button class="btn btn-primary" disabled="@IsBusy" @onclick="UpgradeAllAsync">
                    <span class="bi bi-cloud-arrow-up"></span> Upgrade All
                </button>
            </div>
        </div>

        <div class="tool-status-grid">
            @foreach (var tool in _toolStatuses)
            {
                <div class="tool-status-card @(tool.IsAvailable ? "ok" : "missing")">
                    <div>
                        <strong>@tool.Name</strong>
                        <span class="tool-state @(tool.IsAvailable ? "ok" : "missing")">
                            @if (tool.IsAvailable) { <span class="bi bi-check-circle-fill"></span> <span>Installed</span> }
                            else { <span class="bi bi-exclamation-triangle-fill"></span> <span>Missing</span> }
                        </span>
                    </div>
                    
                    <p>@ToolDetail(tool)</p>
                    
                    <small title="@tool.Path">@((tool.Path ?? "Not found on PATH"))</small>
                    
                    <div class="action-bar">
                        <button class="btn btn-secondary" disabled="@IsBusy" @onclick="() => InstallAsync(tool.Name)">
                            @if (_installing == tool.Name) { <span>Installing...</span> }
                            else { <span class="bi bi-download"></span> @InstallButtonText(tool) }
                        </button>
                        <button class="btn btn-secondary" disabled="@(IsBusy || !tool.IsAvailable)" @onclick="() => UpgradeAsync(tool.Name)">
                            @if (_upgrading == tool.Name) { <span>Checking...</span> }
                            else { <span class="bi bi-arrow-up-circle"></span> <span>Upgrade</span> }
                        </button>
                    </div>
                </div>
            }
        </div>
        
        @if (!string.IsNullOrEmpty(_lastLogOutput))
        {
            <div class="notice">
                <div class="panel-title-row">
                    <strong>Command Output</strong>
                    <button class="btn btn-secondary" @onclick="() => _lastLogOutput = null" title="Clear log">
                        <span class="bi bi-x-lg"></span>
                    </button>
                </div>
                <pre>@_lastLogOutput</pre>
            </div>
        }
    </section>
</div>

@code {
    private string? _installing;
    private string? _upgrading;
    private string? _message;
    private string? _lastLogOutput;
    private IReadOnlyList<ToolStatus> _toolStatuses = [];
    private bool IsBusy => _installing is not null || _upgrading is not null || _upgrading == "*";
    private CancellationTokenSource? _installCts;

    protected override void OnInitialized() => LoadToolStatuses();

    private static string ToolDetail(ToolStatus tool) =>
        tool.IsAvailable ? tool.Version ?? "Installed, version unavailable" : tool.Detail ?? "Command is not available.";

    private string InstallButtonText(ToolStatus tool)
    {
        if (tool.IsAvailable) return tool.Name == "ffprobe" ? "Reinstall ffmpeg" : "Reinstall";
        return tool.Name == "ffprobe" ? "Install ffmpeg" : "Install";
    }

    private void RefreshTools()
    {
        ToolProbe.Refresh();
        LoadToolStatuses();
        _message = "Tool status refreshed.";
        _lastLogOutput = null;
    }

    private void LoadToolStatuses() => _toolStatuses = ToolProbe.GetStatuses();

    private void CancelOperation()
    {
        _installCts?.Cancel();
        _message = "Cancelling operation...";
    }

    private async Task<string> SaveLogIfNeededAsync(string action, string toolName, string output)
    {
        _lastLogOutput = output; // Show in the new beautiful terminal box at the bottom
        if (output.Length <= 500) return "Process completed. See log below for details.";

        try
        {
            var appData = Path.Combine(Environment.GetFolderPath(Environment.SpecialFolder.LocalApplicationData), "media-tools-next", "logs");
            Directory.CreateDirectory(appData);
            var timestamp = DateTime.UtcNow.ToString("yyyyMMdd_HHmmss");
            var filename = $"tool-{action}-{toolName}-{timestamp}.log";
            var logPath = Path.Combine(appData, filename);
            await File.WriteAllTextAsync(logPath, output);
            return $"Log saved to: {logPath}";
        }
        catch (Exception ex)
        {
            return $"Failed to save full log: {ex.Message}";
        }
    }

    private async Task InstallAsync(string toolName)
    {
        _installing = toolName;
        _message = $"Installing {toolName}...";
        _lastLogOutput = null;
        _installCts = new CancellationTokenSource();
        try
        {
            var result = await Installer.InstallAsync(toolName, _installCts.Token);
            var logStatus = await SaveLogIfNeededAsync("install", toolName, result.Output);
            _message = result.Success ? $"Successfully installed {toolName}. {logStatus}" : $"Failed to install {toolName}. {logStatus}";
            ToolProbe.Refresh(); LoadToolStatuses();
        }
        catch (OperationCanceledException) { _message = "Installation cancelled."; }
        catch (Exception ex) { _message = $"Installation error: {ex.Message}"; }
        finally { _installing = null; _installCts?.Dispose(); _installCts = null; }
    }

    private async Task UpgradeAsync(string toolName)
    {
        _upgrading = toolName;
        _message = $"Checking updates for {toolName}...";
        _lastLogOutput = null;
        _installCts = new CancellationTokenSource();
        try
        {
            var result = await Installer.UpgradeAsync(toolName, _installCts.Token);
            var logStatus = await SaveLogIfNeededAsync("upgrade", toolName, result.Output);
            _message = result.Success ? $"Upgrade check completed for {toolName}. {logStatus}" : $"Upgrade check failed for {toolName}. {logStatus}";
            ToolProbe.Refresh(); LoadToolStatuses();
        }
        catch (OperationCanceledException) { _message = "Upgrade cancelled."; }
        catch (Exception ex) { _message = $"Upgrade error: {ex.Message}"; }
        finally { _upgrading = null; _installCts?.Dispose(); _installCts = null; }
    }

    private async Task UpgradeAllAsync()
    {
        _upgrading = "*";
        _message = "Checking updates for all validator tools...";
        _lastLogOutput = null;
        _installCts = new CancellationTokenSource();
        try
        {
            var result = await Installer.UpgradeAllAsync(_toolStatuses.Select(t => t.Name), _installCts.Token);
            var logStatus = await SaveLogIfNeededAsync("upgrade-all", "all", result.Output);
            _message = result.Success ? $"Upgrade checks completed for all tools. {logStatus}" : $"One or more upgrade checks failed. {logStatus}";
            ToolProbe.Refresh(); LoadToolStatuses();
        }
        catch (OperationCanceledException) { _message = "Upgrade operation cancelled."; }
        catch (Exception ex) { _message = $"Upgrade operation error: {ex.Message}"; }
        finally { _upgrading = null; _installCts?.Dispose(); _installCts = null; }
    }
}

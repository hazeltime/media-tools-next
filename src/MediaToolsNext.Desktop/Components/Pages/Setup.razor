@page "/setup"
@inject ScanWorkflowState State
@inject FolderPickerService Picker

<div class="page-stack">
    <header class="page-header">
        <p class="eyebrow">Step 1</p>
        <h1>Setup</h1>
        <p>Choose the source folder and what the app may write. Source files are read only.</p>
    </header>

    <section class="panel">
        <div class="form-grid">
            <label>
                Source folder
                <small>Scanned recursively. Originals are not changed.</small>
                <div class="input-action">
                    <input @bind="State.SourcePath" />
                    <button @onclick="PickSource">Browse</button>
                </div>
            </label>
            @if (State.Mode != ScanActionMode.DryRun)
            {
                <label>
                    Target folder
                    <small>Selected files are written here using the output options.</small>
                    <div class="input-action">
                        <input @bind="State.TargetRoot" />
                        <button @onclick="PickTarget">Browse</button>
                    </div>
                </label>
            }
            @if (State.Mode == ScanActionMode.CopySortedAndBackup)
            {
                <label>
                    Backup folder
                    <small>Receives a mirror of selected target writes.</small>
                    <div class="input-action">
                        <input @bind="State.BackupRoot" />
                        <button @onclick="PickBackup">Browse</button>
                    </div>
                </label>
            }
        </div>
        <div class="info-grid" style="margin-top:12px">
            <div><strong>Source</strong><span>Read-only. Files are opened for validation only.</span></div>
            @if (State.Mode != ScanActionMode.DryRun)
            {
                <div><strong>Target</strong><span>Used only by write modes. Grouping can be by outcome or media category.</span></div>
            }
            @if (State.Mode == ScanActionMode.CopySortedAndBackup)
            {
                <div><strong>Backup</strong><span>Used only by write + backup.</span></div>
            }
        </div>
    </section>

    <section class="panel">
        <h2>Mode</h2>
        <div class="card-grid three">
            <button class="select-card @(State.Mode == ScanActionMode.DryRun ? "active" : "")" @onclick="() => SetMode(ScanActionMode.DryRun)"><strong>Log only</strong><span>Validate and record results. No target writes.</span></button>
            <button class="select-card @(State.Mode == ScanActionMode.CopySorted ? "active" : "")" @onclick="() => SetMode(ScanActionMode.CopySorted)"><strong>Write selected</strong><span>Copy or move selected outcomes to target.</span></button>
            <button class="select-card @(State.Mode == ScanActionMode.CopySortedAndBackup ? "active" : "")" @onclick="() => SetMode(ScanActionMode.CopySortedAndBackup)"><strong>Write + backup</strong><span>Copy or move to target and mirror to backup.</span></button>
        </div>
        @if (State.Mode != ScanActionMode.DryRun)
        {
            <div class="form-grid three" style="margin-top:12px">
                <label>Operation
                    <select @bind="State.ActionOperation">
                        <option value="@FileActionOperation.Copy">Copy files</option>
                        <option value="@FileActionOperation.Move">Move files</option>
                    </select>
                </label>
                <label>Group folders
                    <select @bind="State.OutputGrouping">
                        <option value="@OutputGrouping.Status">By outcome</option>
                        <option value="@OutputGrouping.MediaCategory">By media category</option>
                    </select>
                </label>
                <label>Path layout
                    <select @bind="State.OutputPathLayout">
                        <option value="@OutputPathLayout.PreserveRelativePath">Preserve relative paths</option>
                        <option value="@OutputPathLayout.Flat">Flat destination folders</option>
                    </select>
                </label>
            </div>
            <label class="choice confirm" style="margin-top:12px"><input type="checkbox" @bind="State.ConfirmedLiveMode" /> I understand this mode writes files and move mode removes originals after a successful write.</label>
        }
    </section>

    <section class="panel">
        <h2>Hard limits</h2>
        <p class="muted">Limits count matched files only. The size cap is the total size of all matched files, not a per-file limit. Set to <strong>0</strong> to disable a limit.</p>
        <div class="form-grid three">
            <label>Max scan seconds <input type="number" min="0" @bind="State.MaxRuntimeSeconds" /></label>
            <label>@(State.IsImageOnly ? "Max image files" : "Max matched files") <input type="number" min="0" @bind="State.MaxMatchedFiles" /></label>
            <label>@(State.IsImageOnly ? "Max total image MB" : "Max total matched MB") <input type="number" min="0" @bind="State.MaxMatchedMb" /></label>
        </div>
        <div class="button-row" style="margin-top:10px">
            <button @onclick="Defaults">Default limits</button>
            <button class="secondary" @onclick="Clear">Unlimited (set all to 0)</button>
        </div>
    </section>
</div>

@code {
    private async Task PickSource() => State.SourcePath = await Picker.PickFolderAsync("Select source folder", State.SourcePath) ?? State.SourcePath;
    private async Task PickTarget() => State.TargetRoot = await Picker.PickFolderAsync("Select target folder", State.TargetRoot) ?? State.TargetRoot;
    private async Task PickBackup() => State.BackupRoot = await Picker.PickFolderAsync("Select backup folder", State.BackupRoot) ?? State.BackupRoot;
    private void SetMode(ScanActionMode mode) { if (State.Mode != mode) State.ConfirmedLiveMode = false; State.Mode = mode; }
    private void Defaults() { State.MaxRuntimeSeconds = 30; State.MaxMatchedFiles = 10000; State.MaxMatchedMb = 10240; }
    private void Clear() { State.MaxRuntimeSeconds = 0; State.MaxMatchedFiles = 0; State.MaxMatchedMb = 0; }
}

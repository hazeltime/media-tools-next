@page "/results"
@page "/results/{Tab}"
@inject ScanWorkflowState State
@inject FolderPickerService Picker
@inject IReportExporter CsvExporter
@inject NavigationManager Nav
@implements IDisposable

<div class="page-stack results-workspace" tabindex="0" @onkeydown="HandleKeyAsync">
    <header class="page-header">
        <p class="eyebrow">Review</p>
        <h1>Results</h1>
        <p>Structured scan results. Use filters and tabs to focus on what matters.</p>
    </header>

    @if (!string.IsNullOrWhiteSpace(State.Message)) { <div class="notice">@State.Message</div> }

    <!-- Scan metadata -->
    <section class="panel run-facts">
        <h2>Scan status</h2>
        @if (State.LastRunStartedLocal is null)
        {
            <p class="muted empty-state">No scan has been run yet. Go to Run to start one, or load a saved session from Saved scans.</p>
        }
        else
        {
            <div class="info-grid">
                <div><strong>@State.LastRunType</strong><span>Type</span></div>
                <div><strong>@FormatTime(State.LastRunStartedLocal)</strong><span>Started</span></div>
                <div><strong>@FormatTime(State.LastRunEndedLocal)</strong><span>Ended</span></div>
            </div>
            <p class="muted" style="margin-top:8px">@State.LastRunSettings</p>
            <p class="muted">Completion: @State.LastCompletionReason</p>
        }
    </section>

    <!-- Clickable summary tiles — click to filter -->
    <section class="summary-tiles">
        <!-- Input funnel -->
        <div class="summary-tile-group">
            <span class="summary-tile-group-label">Input</span>
            <button class="summary-tile @(ActiveTab == "searched" ? "active" : "") searched"
                    @onclick='() => SetTab("searched")'>
                <strong>@State.TotalSearched.ToString("N0")</strong><span>Searched</span>
            </button>
            <button class="summary-tile @(ActiveTab == "filtered-size" ? "active" : "") filtered"
                    @onclick='() => SetTab("filtered-size")'>
                <strong>@State.FilteredOutSize.ToString("N0")</strong><span>Filtered · size</span>
                <small>@FormatPercent(State.FilteredOutSize, State.TotalSearched)</small>
            </button>
            <button class="summary-tile @(ActiveTab == "filtered-pattern" ? "active" : "") filtered"
                    @onclick='() => SetTab("filtered-pattern")'>
                <strong>@State.FilteredOutPattern.ToString("N0")</strong><span>Filtered · pattern</span>
                <small>@FormatPercent(State.FilteredOutPattern, State.TotalSearched)</small>
            </button>
            <button class="summary-tile @(ActiveTab == "filtered-family" ? "active" : "") filtered"
                    @onclick='() => SetTab("filtered-family")'>
                <strong>@State.FilteredOutFamily.ToString("N0")</strong><span>Filtered · family</span>
                <small>@FormatPercent(State.FilteredOutFamily, State.TotalSearched)</small>
            </button>
            <button class="summary-tile @(ActiveTab == "all" ? "active" : "") total"
                    @onclick='() => SetTab("all")'>
                <strong>@State.Results.Count.ToString("N0")</strong><span>Matched</span>
                <small>@FormatPercent(State.Results.Count, State.TotalSearched)</small>
            </button>
        </div>
        <!-- Outcomes -->
        <div class="summary-tile-group">
            <span class="summary-tile-group-label">Outcomes</span>
            @foreach (var st in Enum.GetValues<ValidationStatus>())
            {
                var tabKey = st.ToString().ToLowerInvariant();
                <button class="summary-tile @(ActiveTab == tabKey ? "active" : "") @tabKey"
                        @onclick="() => SetTab(tabKey)">
                    <strong>@State.GetStatusCount(st).ToString("N0")</strong>
                    <span>@st</span>
                    <small>@FormatPercent(State.GetStatusCount(st), State.Results.Count)</small>
                </button>
            }
        </div>
    </section>

    <!-- Tab content -->
    @if (ActiveTab is "searched" or "filtered-size" or "filtered-pattern" or "filtered-family")
    {
        <section class="panel">
            <h2>@TabTitle</h2>
            <p class="muted">@TabDescription</p>
            <div class="summary-grid">
                <div><strong>@FilteredCount.ToString("N0")</strong><span>@TabTitle</span></div>
            </div>
        </section>
    }
    else
    {
        <!-- Toolbar -->
        <section class="result-toolbar panel">
            <label>Search path or detail
                <input @bind="_searchText" @bind:event="oninput" @bind:after="RebuildCache" placeholder="filename, folder, validator detail…" />
            </label>
            <label>Sort
                <select @bind="State.ReportSort" @bind:after="RebuildCache">
                    <option value="status-path">Status, then path</option>
                    <option value="path">Path</option>
                    <option value="size-desc">Largest first</option>
                    <option value="detail">Detail</option>
                    <option value="validator">Validator</option>
                    <option value="time">Scan order</option>
                    <option value="newest">Newest first</option>
                </select>
            </label>
            <label>Error/detail group
                <select @bind="_detailGroup" @bind:after="RebuildCache">
                    <option value="">All details</option>
                    @foreach (var detail in DetailGroups)
                    {
                        <option value="@detail">@detail</option>
                    }
                </select>
            </label>
            <label>Rows
                <select @bind="_pageSize" @bind:after="ResetPage">
                    <option value="25">25/page</option>
                    <option value="50">50/page</option>
                    <option value="100">100/page</option>
                    <option value="250">250/page</option>
                </select>
            </label>
            <button class="secondary" disabled="@(!State.Results.Any())" @onclick="ExportAsync"
                    title="Export @State.Results.Count.ToString("N0") results as @State.ReportFormat.ToUpperInvariant()">
                Export @State.ReportFormat.ToUpperInvariant()
            </button>
        </section>

        <!-- Context actions per tab -->
        <section class="panel results-actions">
            <div class="action-bar">
                <button class="secondary" disabled="@(!_pagedRows.Any())" @onclick="SelectPage">Select page</button>
                <button class="secondary" disabled="@(!_visibleRows.Any())" @onclick="SelectFiltered">Select filtered</button>
                <button class="secondary" disabled="@(_selectedKeys.Count == 0)" @onclick="ClearSelection">Clear selection</button>
                <button disabled="@(_selectedKeys.Count == 0)" @onclick="() => WriteSelectedAsync(FileActionOperation.Copy, OutputPathLayout.PreserveRelativePath)">Copy relative</button>
                <button disabled="@(_selectedKeys.Count == 0)" @onclick="() => WriteSelectedAsync(FileActionOperation.Copy, OutputPathLayout.Flat)">Copy flat</button>
                <button class="danger" disabled="@(_selectedKeys.Count == 0)" @onclick="() => WriteSelectedAsync(FileActionOperation.Move, OutputPathLayout.PreserveRelativePath)">Move relative</button>
                <button class="danger" disabled="@(_selectedKeys.Count == 0)" @onclick="() => WriteSelectedAsync(FileActionOperation.Move, OutputPathLayout.Flat)">Move flat</button>
            </div>
            <p class="muted">@_selectedKeys.Count.ToString("N0") selected. Batch writes use the filtered source paths and keep current result rows unchanged.</p>
        </section>

        @if (ActiveTab == "corrupt")
        {
            <section class="panel context-actions">
                <h2>Corrupt files — actions</h2>
                <div class="action-bar">
                    <button class="secondary" @onclick="OpenCorruptFolder">Open output folder</button>
                    <button class="secondary" @onclick="() => ExportFilteredAsync(ValidationStatus.Corrupt)">Export list (CSV)</button>
                    <button class="secondary" @onclick="CopyCorruptPaths">Copy visible paths to clipboard</button>
                </div>
                <p class="muted" style="margin-top:0.5rem">Corrupt files failed at least one validator check. Inspect the Detail column for the specific failure reason.</p>
            </section>
        }
        else if (ActiveTab == "valid")
        {
            <section class="panel context-actions">
                <h2>Valid files — actions</h2>
                <div class="action-bar">
                    <button class="secondary" @onclick="OpenValidFolder">Open output folder</button>
                    <button class="secondary" @onclick="() => ExportFilteredAsync(ValidationStatus.Valid)">Export list (CSV)</button>
                    <button class="secondary" @onclick="CopyValidPaths">Copy visible paths to clipboard</button>
                </div>
            </section>
        }
        else if (ActiveTab == "unknown")
        {
            <section class="panel context-actions">
                <h2>Unknown files — actions</h2>
                <div class="action-bar">
                    <button class="secondary" @onclick="() => ExportFilteredAsync(ValidationStatus.Unknown)">Export list (CSV)</button>
                    <button class="secondary" @onclick="CopyUnknownPaths">Copy visible paths to clipboard</button>
                </div>
                <p class="muted" style="margin-top:0.5rem">Unknown means validation was inconclusive, not proven corrupt: missing external tools, encrypted PDFs, warning-only tool results, unknown image headers, or a validator that could not make a definitive decision.</p>
            </section>
        }
        else if (ActiveTab == "error")
        {
            <section class="panel context-actions">
                <h2>Error files — actions</h2>
                <div class="action-bar">
                    <button class="secondary" @onclick="() => ExportFilteredAsync(ValidationStatus.Error)">Export list (CSV)</button>
                    <button class="secondary" @onclick="CopyErrorPaths">Copy visible paths to clipboard</button>
                </div>
                <p class="muted" style="margin-top:0.5rem">Error means the validator itself threw an exception (I/O error, tool crash, timeout). The file may or may not be corrupt — retry with Force rescan enabled.</p>
            </section>
        }
        else if (ActiveTab == "skipped")
        {
            <section class="panel context-actions">
                <h2>Skipped files</h2>
                <p class="muted">Skipped is a pipeline-only result for matched files that had no validator. Most unsupported or disabled files are counted earlier as Filtered family, so Skipped is normally zero.</p>
            </section>
        }

        <div class="results-layout @(_previewPinned ? "has-preview" : "")">
            <div class="results-main">
                <!-- Results table -->
                <section class="panel results-panel">
                    <div class="result-count">
                        <strong>@_filteredCount.ToString("N0")</strong>
                        <span>
                            page @(_page + 1) of @TotalPages, showing @_pagedRows.Count.ToString("N0") rows.
                        </span>
                    </div>
                    @if (State.GroupReportByStatus && _visibleRows.Count > 0)
                    {
                        @foreach (var group in _pagedRows.GroupBy(r => r.Status))
                        {
                            <h3 class="result-group-heading">@group.Key <span>@group.Count().ToString("N0")</span></h3>
                            @ResultTable(group)
                        }
                    }
                    else
                    {
                        @ResultTable(_pagedRows)
                    }
                    <div class="pager">
                        <button class="secondary compact" disabled="@(_page == 0)" @onclick="PreviousPage">Prev</button>
                        <span>@((_pageStart + 1).ToString("N0"))-@Math.Min(_pageStart + _pageSize, _filteredCount).ToString("N0") of @_filteredCount.ToString("N0")</span>
                        <button class="secondary compact" disabled="@(_page >= TotalPages - 1)" @onclick="NextPage">Next</button>
                    </div>
                </section>
            </div>

            @if (_previewPinned)
            {
                <aside class="preview-panel @(_previewCollapsed ? "collapsed" : "")">
                    <div class="preview-head">
                        <strong>@(_previewRow?.Candidate.RelativePath ?? "Preview")</strong>
                        <button class="secondary compact" disabled="@(!_imageRows.Any())" @onclick="PreviousImageAsync">Prev</button>
                        <button class="secondary compact" disabled="@(!_imageRows.Any())" @onclick="NextImageAsync">Next</button>
                        <button class="secondary compact" @onclick="() => _previewCollapsed = !_previewCollapsed">@(_previewCollapsed ? "Expand" : "Fold")</button>
                        <button class="secondary compact" @onclick="() => _previewPinned = false">Unpin</button>
                    </div>
                    @if (!_previewCollapsed)
                    {
                        @PreviewContent()
                    }
                </aside>
            }
        </div>
    }

    @if (_previewRow is not null && !_previewPinned)
    {
        <div class="preview-overlay" @onclick="ClosePreview" role="dialog" aria-modal="true" aria-label="Image preview">
            <div class="preview-box" @onclick:stopPropagation>
                <div class="preview-head">
                    <strong>@_previewRow.Candidate.RelativePath</strong>
                    <button class="secondary compact" @onclick="() => _previewPinned = true">Pin</button>
                    <button class="secondary compact" @onclick="PreviousImageAsync">Prev</button>
                    <button class="secondary compact" @onclick="NextImageAsync">Next</button>
                    <button class="secondary compact" @onclick="OpenPreviewExternal">Open</button>
                    <button class="secondary compact" @onclick="ClosePreview">Close</button>
                </div>
                @PreviewContent()
            </div>
        </div>
    }
</div>

@code {
    private RenderFragment PreviewContent() => @<div class="preview-content">
        @if (_previewDataUri is not null && _previewRow is not null)
        {
            <img src="@_previewDataUri" alt="@_previewRow.Candidate.RelativePath" />
        }
        else
        {
            <p class="muted">Preview is unavailable for this file size or type. Use Open to launch it externally.</p>
        }
    </div>;

    private RenderFragment ResultTable(IEnumerable<ScanResultRecord> rows) => @<table class="results-table">
                <colgroup><col class="select-col" /><col class="status-col" /><col class="type-col" /><col /><col class="size-col" /><col class="validator-col" /><col class="detail-col" /></colgroup>
                <thead><tr><th><input type="checkbox" checked="@IsPageSelected" @onchange="e => TogglePage((bool)e.Value!)" /></th><th>Status</th><th>Type</th><th>Path</th><th>Size</th><th>Validator</th><th>Detail</th></tr></thead>
                <tbody>
                    @foreach (var row in rows)
                    {
                        var key = RowKey(row);
                        <tr class="@(IsCurrentPreview(row) ? "current-row" : "")">
                            <td><input type="checkbox" checked="@_selectedKeys.Contains(key)" @onchange="e => ToggleRow(row, (bool)e.Value!)" /></td>
                            <td><span class="status-pill @row.Status.ToString().ToLowerInvariant()">@row.Status</span></td>
                            <td>@row.Candidate.Category</td>
                            <td title="@row.Candidate.FullPath">
                                @if (row.Candidate.Category == MediaCategory.Image)
                                {
                                    <button class="result-path-button" @onclick="() => PreviewImageAsync(row)">@row.Candidate.RelativePath</button>
                                }
                                else
                                {
                                    <span class="path-cell">@row.Candidate.RelativePath</span>
                                }
                            </td>
                            <td>@FormatBytes(row.Candidate.SizeBytes)</td>
                            <td>@row.Validator</td>
                            <td><span class="detail-cell" title="@row.Detail">@row.Detail</span></td>
                        </tr>
                    }
                    @if (!rows.Any())
                    {
                        <tr><td colspan="7" class="empty-cell">No results match the current filter.</td></tr>
                    }
                </tbody>
            </table>;
    [Parameter] public string? Tab { get; set; }

    private string ActiveTab = "all";
    private string _searchText = string.Empty;
    private string _detailGroup = string.Empty;
    private List<ScanResultRecord> _visibleRows  = [];
    private List<ScanResultRecord> _pagedRows  = [];
    private List<ScanResultRecord> _imageRows = [];
    private int                    _filteredCount = 0;
    private int _page;
    private int _pageSize = 50;
    private int _pageStart => _page * _pageSize;
    private int TotalPages => Math.Max(1, (int)Math.Ceiling(_filteredCount / (double)_pageSize));
    private readonly HashSet<string> _selectedKeys = new(StringComparer.OrdinalIgnoreCase);
    private ScanResultRecord? _previewRow;
    private string? _previewDataUri;
    private bool _previewPinned = true;
    private bool _previewCollapsed;

    private string TabTitle => ActiveTab switch
    {
        "searched"         => "Searched",
        "filtered-size"    => "Filtered out · size",
        "filtered-pattern" => "Filtered out · pattern",
        "filtered-family"  => "Filtered out · family",
        _                  => ActiveTab
    };

    private string TabDescription => ActiveTab switch
    {
        "searched"         => "Total files the discoverer inspected before applying any filter.",
        "filtered-size"    => "Files dropped because they were smaller than the minimum or larger than the maximum file size configured on the Media page.",
        "filtered-pattern" => "Files dropped because their filename did not match an include pattern, or matched an exclude pattern.",
        "filtered-family"  => "Files dropped because their extension belongs to a media family that was not enabled.",
        _                  => string.Empty
    };

    private long FilteredCount => ActiveTab switch
    {
        "searched"         => State.TotalSearched,
        "filtered-size"    => State.FilteredOutSize,
        "filtered-pattern" => State.FilteredOutPattern,
        "filtered-family"  => State.FilteredOutFamily,
        _                  => 0
    };
    private IReadOnlyList<string> DetailGroups => State.Results
        .Select(r => NormalizeDetail(r.Detail))
        .Where(x => !string.IsNullOrWhiteSpace(x))
        .Distinct(StringComparer.OrdinalIgnoreCase)
        .OrderBy(x => x, StringComparer.OrdinalIgnoreCase)
        .Take(50)
        .ToArray();

    protected override void OnInitialized()
    {
        ActiveTab = ResolveTab(Tab);
        State.Changed += OnStateChanged;
        RebuildCache();
    }

    protected override void OnParametersSet()
    {
        ActiveTab = ResolveTab(Tab);
        RebuildCache();
    }

    public void Dispose() => State.Changed -= OnStateChanged;

    private void SetTab(string tab)
    {
        Nav.NavigateTo($"/results/{tab}");
    }

    private void OnStateChanged() => InvokeAsync(() => { RebuildCache(); StateHasChanged(); });

    private static string ResolveTab(string? tab) => string.IsNullOrWhiteSpace(tab) ? "all" : tab.ToLowerInvariant();

    private void RebuildCache()
    {
        if (ActiveTab is "searched" or "filtered-size" or "filtered-pattern" or "filtered-family")
        {
            _filteredCount = 0;
            _visibleRows   = [];
            return;
        }

        ValidationStatus? statusFilter = ActiveTab switch
        {
            "valid"   => ValidationStatus.Valid,
            "corrupt" => ValidationStatus.Corrupt,
            "unknown" => ValidationStatus.Unknown,
            "error"   => ValidationStatus.Error,
            "skipped" => ValidationStatus.Skipped,
            _         => (ValidationStatus?)null
        };

        var sorted = State.ReportSort switch
        {
            "path"        => State.Results.OrderBy(x => x.Candidate.RelativePath),
            "size-desc"   => State.Results.OrderByDescending(x => x.Candidate.SizeBytes),
            "status-path" => State.Results.OrderBy(x => x.Status).ThenBy(x => x.Candidate.RelativePath),
            "detail"      => State.Results.OrderBy(x => NormalizeDetail(x.Detail)).ThenBy(x => x.Candidate.RelativePath),
            "validator"   => State.Results.OrderBy(x => x.Validator).ThenBy(x => x.Candidate.RelativePath),
            "newest"      => State.Results.OrderByDescending(x => x.TimestampUtc),
            _             => (IEnumerable<ScanResultRecord>)State.Results
        };

        var filtered = sorted.Where(r =>
        {
            if (statusFilter.HasValue && r.Status != statusFilter.Value) return false;
            if (!string.IsNullOrWhiteSpace(_detailGroup) && !NormalizeDetail(r.Detail).Equals(_detailGroup, StringComparison.OrdinalIgnoreCase)) return false;
            if (string.IsNullOrWhiteSpace(_searchText)) return true;
            return r.Candidate.RelativePath.Contains(_searchText, StringComparison.OrdinalIgnoreCase)
                || r.Candidate.FullPath.Contains(_searchText, StringComparison.OrdinalIgnoreCase)
                || (r.Detail?.Contains(_searchText, StringComparison.OrdinalIgnoreCase) ?? false)
                || r.Validator.Contains(_searchText, StringComparison.OrdinalIgnoreCase);
        }).ToList();

        _filteredCount = filtered.Count;
        _visibleRows   = filtered;
        _page = Math.Clamp(_page, 0, TotalPages - 1);
        _pagedRows = _visibleRows.Skip(_pageStart).Take(_pageSize).ToList();
        _imageRows = _visibleRows.Where(r => r.Candidate.Category == MediaCategory.Image).ToList();
    }

    private Task CopyCorruptPaths()  => CopyPathsForStatus(ValidationStatus.Corrupt);
    private Task CopyValidPaths()    => CopyPathsForStatus(ValidationStatus.Valid);
    private Task CopyUnknownPaths()  => CopyPathsForStatus(ValidationStatus.Unknown);
    private Task CopyErrorPaths()    => CopyPathsForStatus(ValidationStatus.Error);

    private async Task CopyPathsForStatus(ValidationStatus status)
    {
        var paths = _visibleRows
            .Where(r => r.Status == status)
            .Select(r => r.Candidate.FullPath);
        var copiedCount = paths.Count();
        try
        {
            await Microsoft.Maui.ApplicationModel.DataTransfer.Clipboard.Default
                .SetTextAsync(string.Join(Environment.NewLine, paths));
            State.Message = $"Copied {copiedCount:N0} visible {status} paths to clipboard.";
        }
        catch { State.Message = "Clipboard not available in this context."; }
        State.NotifyChanged();
    }

    private bool IsPageSelected => _pagedRows.Count > 0 && _pagedRows.All(r => _selectedKeys.Contains(RowKey(r)));
    private static string RowKey(ScanResultRecord row) => row.Candidate.FullPath + "|" + row.TimestampUtc.ToUnixTimeMilliseconds();
    private bool IsCurrentPreview(ScanResultRecord row) => _previewRow is not null && RowKey(_previewRow) == RowKey(row);

    private void ToggleRow(ScanResultRecord row, bool selected)
    {
        var key = RowKey(row);
        if (selected) _selectedKeys.Add(key);
        else _selectedKeys.Remove(key);
    }

    private void TogglePage(bool selected)
    {
        foreach (var row in _pagedRows)
            ToggleRow(row, selected);
    }

    private void SelectPage()
    {
        foreach (var row in _pagedRows)
            _selectedKeys.Add(RowKey(row));
    }

    private void SelectFiltered()
    {
        foreach (var row in _visibleRows)
            _selectedKeys.Add(RowKey(row));
    }

    private void ClearSelection() => _selectedKeys.Clear();

    private void PreviousPage()
    {
        if (_page > 0) _page--;
        RebuildCache();
    }

    private void NextPage()
    {
        if (_page < TotalPages - 1) _page++;
        RebuildCache();
    }

    private void ResetPage()
    {
        _page = 0;
        RebuildCache();
    }

    private async Task WriteSelectedAsync(FileActionOperation operation, OutputPathLayout layout)
    {
        var destination = await Picker.PickFolderAsync($"{operation} selected files", State.TargetRoot);
        if (string.IsNullOrWhiteSpace(destination)) return;
        var selected = State.Results.Where(r => _selectedKeys.Contains(RowKey(r))).ToList();
        var written = 0;
        foreach (var row in selected)
        {
            if (!File.Exists(row.Candidate.FullPath)) continue;
            var target = BuildManualTarget(destination, row, layout);
            Directory.CreateDirectory(Path.GetDirectoryName(target)!);
            target = GetSafePath(target);
            if (operation == FileActionOperation.Copy)
            {
                File.Copy(row.Candidate.FullPath, target);
            }
            else
            {
                File.Move(row.Candidate.FullPath, target);
            }
            written++;
        }
        State.Message = $"{operation} completed for {written:N0} selected files.";
        State.NotifyChanged();
    }

    private static string BuildManualTarget(string root, ScanResultRecord row, OutputPathLayout layout)
    {
        var relative = layout == OutputPathLayout.Flat ? Path.GetFileName(row.Candidate.RelativePath) : row.Candidate.RelativePath;
        var parts = relative
            .TrimStart(Path.DirectorySeparatorChar, Path.AltDirectorySeparatorChar)
            .Split([Path.DirectorySeparatorChar, Path.AltDirectorySeparatorChar], StringSplitOptions.RemoveEmptyEntries);
        return Path.Combine([root, .. parts]);
    }

    private static string GetSafePath(string target)
    {
        if (!File.Exists(target)) return target;
        var dir = Path.GetDirectoryName(target)!;
        var name = Path.GetFileNameWithoutExtension(target);
        var ext = Path.GetExtension(target);
        for (var i = 1; ; i++)
        {
            var candidate = Path.Combine(dir, $"{name}_{i}{ext}");
            if (!File.Exists(candidate)) return candidate;
        }
    }

    private async Task PreviewImageAsync(ScanResultRecord row)
    {
        if (!File.Exists(row.Candidate.FullPath))
        {
            State.Message = "Image file no longer exists: " + row.Candidate.FullPath;
            State.NotifyChanged();
            return;
        }

        _previewRow = row;
        _previewDataUri = null;
        try
        {
            var currentSizeBytes = new FileInfo(row.Candidate.FullPath).Length;
            if (currentSizeBytes <= 10 * 1024 * 1024)
            {
                var bytes = await File.ReadAllBytesAsync(row.Candidate.FullPath);
                _previewDataUri = $"data:{ImageMime(row.Candidate.Extension)};base64,{Convert.ToBase64String(bytes)}";
            }
        }
        catch (Exception ex)
        {
            State.Message = "Could not preview image: " + ex.Message;
            State.NotifyChanged();
        }
    }

    private void ClosePreview()
    {
        _previewRow = null;
        _previewDataUri = null;
    }

    private async Task PreviousImageAsync()
    {
        if (_imageRows.Count == 0) return;
        var index = CurrentImageIndex();
        index = index <= 0 ? _imageRows.Count - 1 : index - 1;
        await PreviewImageAsync(_imageRows[index]);
    }

    private async Task NextImageAsync()
    {
        if (_imageRows.Count == 0) return;
        var index = CurrentImageIndex();
        index = index < 0 || index >= _imageRows.Count - 1 ? 0 : index + 1;
        await PreviewImageAsync(_imageRows[index]);
    }

    private int CurrentImageIndex() =>
        _previewRow is null ? -1 : _imageRows.FindIndex(r => RowKey(r) == RowKey(_previewRow));

    private async Task HandleKeyAsync(Microsoft.AspNetCore.Components.Web.KeyboardEventArgs args)
    {
        if (args.Key is "PageDown" or "ArrowRight")
            await NextImageAsync();
        else if (args.Key is "PageUp" or "ArrowLeft")
            await PreviousImageAsync();
    }

    private void OpenPreviewExternal()
    {
        if (_previewRow is not null)
            OpenFile(_previewRow.Candidate.FullPath);
    }

    private void OpenFile(string path)
    {
        if (!File.Exists(path))
        {
            State.Message = "File not found: " + path;
            State.NotifyChanged();
            return;
        }

        try { System.Diagnostics.Process.Start(new System.Diagnostics.ProcessStartInfo { FileName = path, UseShellExecute = true }); }
        catch (Exception ex) { State.Message = $"Could not open file: {ex.Message}"; State.NotifyChanged(); }
    }

    private void OpenValidFolder()   => OpenFolder(OutputFolder("valid"),   "Valid");
    private void OpenCorruptFolder() => OpenFolder(OutputFolder("corrupt"), "Corrupt");
    private string OutputFolder(string statusFolder) =>
        State.OutputGrouping == OutputGrouping.Status ? Path.Combine(State.TargetRoot, statusFolder) : State.TargetRoot;

    private void OpenFolder(string path, string label)
    {
        if (!Directory.Exists(path))
        {
            State.Message = $"{label} output folder not found: {path}. Run a copy-mode scan first.";
            State.NotifyChanged();
            return;
        }
        try { System.Diagnostics.Process.Start(new System.Diagnostics.ProcessStartInfo { FileName = path, UseShellExecute = true }); }
        catch (Exception ex) { State.Message = $"Could not open folder: {ex.Message}"; State.NotifyChanged(); }
    }

    private async Task ExportAsync() => await ExportFilteredAsync(null);

    private async Task ExportFilteredAsync(ValidationStatus? status)
    {
        var source = status.HasValue
            ? State.Results.Where(r => r.Status == status.Value)
            : (IEnumerable<ScanResultRecord>)State.Results;

        var rows = State.ReportSort switch
        {
            "path"        => source.OrderBy(x => x.Candidate.RelativePath),
            "size-desc"   => source.OrderByDescending(x => x.Candidate.SizeBytes),
            "status-path" => source.OrderBy(x => x.Status).ThenBy(x => x.Candidate.RelativePath),
            "detail"      => source.OrderBy(x => NormalizeDetail(x.Detail)).ThenBy(x => x.Candidate.RelativePath),
            "validator"   => source.OrderBy(x => x.Validator).ThenBy(x => x.Candidate.RelativePath),
            "newest"      => source.OrderByDescending(x => x.TimestampUtc),
            _             => source
        };

        var defaultName = status.HasValue
            ? $"media-tools-{status.Value.ToString().ToLowerInvariant()}.{State.ReportFormat}"
            : $"media-tools-results.{State.ReportFormat}";
        var path = await Picker.PickCsvSavePathAsync(defaultName);
        if (string.IsNullOrWhiteSpace(path)) return;
        if (State.ReportFormat == "csv") await CsvExporter.ExportCsvAsync(rows, path, CancellationToken.None);
        else await File.WriteAllLinesAsync(path, rows.Select(x => $"{x.Status}\t{x.Candidate.Category}\t{x.Candidate.RelativePath}\t{x.Detail}"));
        State.Message = "Exported: " + path;
        State.NotifyChanged();
    }

    private static string FormatBytes(long bytes)
    {
        if (bytes >= 1_048_576) return (bytes / 1_048_576d).ToString("N1") + " MB";
        if (bytes >= 1_024)     return (bytes / 1_024d).ToString("N1") + " KB";
        return bytes + " B";
    }

    private static string FormatTime(DateTimeOffset? value) => value?.ToString("yyyy-MM-dd HH:mm:ss") ?? "-";
    private static string FormatPercent(double value, double total) => total <= 0 ? "n/a" : $"{Math.Clamp(value / total, 0, 1):P0}";
    private static string NormalizeDetail(string? detail) => string.IsNullOrWhiteSpace(detail) ? "No detail" : detail.Split(['\r', '\n'], StringSplitOptions.RemoveEmptyEntries).FirstOrDefault()?.Trim() ?? "No detail";
    private static string ImageMime(string extension) => extension.ToLowerInvariant() switch
    {
        ".jpg" or ".jpeg" or ".jpe" or ".jfif" => "image/jpeg",
        ".png" => "image/png",
        ".gif" => "image/gif",
        ".webp" => "image/webp",
        ".bmp" or ".dib" => "image/bmp",
        ".svg" => "image/svg+xml",
        _ => "application/octet-stream"
    };
}

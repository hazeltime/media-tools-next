<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="">Media Tools Next</a>
    </div>
</div>

<input type="checkbox" title="Navigation menu" aria-label="Toggle navigation menu" aria-controls="nav-scrollable" class="navbar-toggler" />

<div id="nav-scrollable" class="nav-scrollable" onclick="document.querySelector('.navbar-toggler').click()">
    <nav class="nav flex-column">
        <div class="nav-section">Workflow</div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                <span class="bi bi-folder-nav-menu" aria-hidden="true"></span> Configure
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="run">
                <span class="bi bi-play-nav-menu" aria-hidden="true"></span> Run
            </NavLink>
        </div>

        <div class="nav-section">Review</div>
        <div class="nav-item px-3 nav-result-root">
            <button type="button" class="nav-tree-toggle" title="@(_resultsOpen ? "Collapse results" : "Expand results")" @onclick="() => _resultsOpen = !_resultsOpen" @onclick:stopPropagation>
                <span class="bi @(_resultsOpen ? "bi-chevron-down-nav-menu" : "bi-chevron-right-nav-menu")" aria-hidden="true"></span>
            </button>
            <NavLink class="nav-link" href="results" Match="NavLinkMatch.All">
                <span class="bi bi-table-nav-menu" aria-hidden="true"></span> Results · All
            </NavLink>
        </div>
        @if (_resultsOpen)
        {
            <div class="nav-item px-3 nav-sub">
                <NavLink class="nav-link nav-link-sub" href="results/valid"><span class="bi bi-valid-nav-menu" aria-hidden="true"></span> Valid</NavLink>
            </div>
            <div class="nav-item px-3 nav-sub">
                <NavLink class="nav-link nav-link-sub" href="results/corrupt"><span class="bi bi-corrupt-nav-menu" aria-hidden="true"></span> Corrupt</NavLink>
            </div>
            <div class="nav-item px-3 nav-sub">
                <NavLink class="nav-link nav-link-sub" href="results/unknown"><span class="bi bi-unknown-nav-menu" aria-hidden="true"></span> Unknown</NavLink>
            </div>
            <div class="nav-item px-3 nav-sub">
                <NavLink class="nav-link nav-link-sub" href="results/error"><span class="bi bi-error-nav-menu" aria-hidden="true"></span> Error</NavLink>
            </div>
            <div class="nav-item px-3 nav-sub">
                <NavLink class="nav-link nav-link-sub" href="results/skipped"><span class="bi bi-skipped-nav-menu" aria-hidden="true"></span> Skipped</NavLink>
            </div>
        }
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="history">
                <span class="bi bi-clock-nav-menu" aria-hidden="true"></span> Saved scans
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="tools">
                <span class="bi bi-tools-nav-menu" aria-hidden="true"></span> Tools
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="help">
                <span class="bi bi-help-nav-menu" aria-hidden="true"></span> Help
            </NavLink>
        </div>

        <div class="nav-item px-3 nav-about-item">
            <button class="nav-link nav-about-btn" @onclick="() => _aboutOpen = true">
                <span class="bi bi-info-nav-menu" aria-hidden="true"></span> About
            </button>
        </div>
    </nav>
</div>

@if (_aboutOpen)
{
    <div class="about-overlay" @onclick="() => _aboutOpen = false" role="dialog" aria-modal="true" aria-label="About Media Tools Next">
        <div class="about-box" @onclick:stopPropagation>
            <h2>Media Tools Next</h2>
            <p class="about-version">v0.1.0.0 alpha</p>
            <div class="about-links">
                <a href="https://github.com/hazeltime" target="_blank" rel="noopener noreferrer">github.com/hazeltime</a>
                <a href="mailto:berrat2@gmail.com">berrat2@gmail.com</a>
            </div>
            <button class="about-close" @onclick="() => _aboutOpen = false">Close</button>
        </div>
    </div>
}

@code {
    private bool _aboutOpen;
    private bool _resultsOpen = true;
}
